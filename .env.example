# File mẫu các biến môi trường cần có khi deploy (Vercel + Supabase).

# --- Database: Supabase Postgres ---
# Lấy ở Supabase Dashboard → Connect → ORMs (Prisma).
# DATABASE_URL: chuỗi "Transaction pooler" (port 6543) — dùng lúc app chạy.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: chuỗi "Session"/direct (port 5432) — dùng khi chạy migrate/db push.
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres"

# --- Supabase Storage (lưu ảnh upload) ---
# Lấy ở Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role-key-bi-mat"

# --- Bảo mật ---
# Khoá ký JWT — BẮT BUỘC ngẫu nhiên & bí mật ở production.
# Tạo bằng: openssl rand -base64 32
AUTH_SECRET="thay-bang-chuoi-ngau-nhien-32-ky-tu-tro-len"
