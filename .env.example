# File mẫu. KHÔNG cần tạo tay khi deploy:
# script deploy/2-deploy.sh sẽ tự sinh file .env với AUTH_SECRET ngẫu nhiên.
# File này chỉ để tham khảo các biến cần có.

# Database SQLite cho production (file nằm trong thư mục dự án trên VM)
DATABASE_URL="file:./prod.db"

# Khoá ký JWT — BẮT BUỘC ngẫu nhiên & bí mật ở production.
# Tạo bằng: openssl rand -base64 32
AUTH_SECRET="thay-bang-chuoi-ngau-nhien-32-ky-tu-tro-len"
